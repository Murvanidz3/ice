RewriteEngine On

# If the request is for the API folder, let it pass through directly
RewriteRule ^api/ - [L]

# If the request is for an actual file in dist/, serve it
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
RewriteRule ^(.*)$ dist/$1 [L]

# If the request is for an actual directory in dist/, serve it
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -d
RewriteRule ^(.*)$ dist/$1 [L]

# Otherwise, serve dist/index.html (React SPA routing)
RewriteRule ^(.*)$ dist/index.html [L]
